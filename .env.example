# このファイルをコピーして .env を作成し、実際のAPIキーを設定してください。
# 例: cp .env.example .env
#
# .env はGit管理対象外（.gitignore）です。実際のキーをコミットしないでください。

# 使用する生成AIプロバイダー。anthropic / openai / gemini から選択（現時点でopenai・geminiは未実装）
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=your-api-key-here

# 将来的にOpenAI APIやGemini APIへ切り替える場合に設定する（providers/openai_provider.py・providers/gemini_provider.py の実装後に使用）
# OPENAI_API_KEY=your-openai-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here
